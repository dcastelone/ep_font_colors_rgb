    <div class="ep-font-colors-rgb-custom">
      <input class="ep-font-colors-rgb-picker" type="color" value="#000000" aria-label="Font color picker">
      <input class="ep-font-colors-rgb-value" type="text" value="" placeholder="#000000" aria-label="Font color value">
